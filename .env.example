##############################################################################
#  NexGen Finance — Environment Variables
#  Copy to .env for local development. NEVER commit .env to version control.
##############################################################################

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=10000

# ── Database ──────────────────────────────────────────────────────────────────
# Local:      postgresql://postgres:password@localhost:5432/nexgen_finance
# Render:     Auto-populated from render.yaml
DATABASE_URL=postgresql://postgres:password@localhost:5432/nexgen_finance

# ── Security ──────────────────────────────────────────────────────────────────
# Generate:   openssl rand -hex 64
JWT_ACCESS_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_64
JWT_REFRESH_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_64
SESSION_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# AES-256 encryption key — MUST be exactly 64 hex chars (32 bytes)
# Generate:   openssl rand -hex 32
ENCRYPTION_KEY=CHANGE_ME_64char_hex_string_here_exactly_64_chars_no_spaces

# JWT token lifetimes
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── OAuth2 — Google ───────────────────────────────────────────────────────────
# Register at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:10000/api/auth/google/callback

# ── OAuth2 — GitHub ───────────────────────────────────────────────────────────
# Register at: https://github.com/settings/applications/new
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:10000/api/auth/github/callback

# ── OAuth2 — Microsoft ────────────────────────────────────────────────────────
# Register at: https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_CALLBACK_URL=http://localhost:10000/api/auth/microsoft/callback
MICROSOFT_TENANT_ID=common

# ── CORS & Frontend ───────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:10000
CORS_ORIGINS=http://localhost:10000,http://localhost:3000

# ── Compliance ────────────────────────────────────────────────────────────────
SEC_RETENTION_YEARS=7
POLICY_VERSION=1.0.0
DPO_EMAIL=privacy@corverxis.com

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=debug
LOG_DIR=./logs

# ── Redis (optional — falls back to in-memory rate limiting) ─────────────────
# REDIS_URL=redis://localhost:6379
